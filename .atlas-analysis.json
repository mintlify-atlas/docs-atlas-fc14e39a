  "keyFeatures": [
    "Four dedicated REST clients: MainClient (Spot/Margin/Wallet), USDMClient (USD-M Futures), CoinMClient (COIN-M Futures), PortfolioClient (Portfolio Margin)",
    "Unified WebsocketClient supporting all product groups with automatic reconnection and heartbeat management",
    "WebsocketAPIClient providing a promise/async-await interface over the WebSocket API",
    "Full TypeScript support with strongly typed requests and responses for all endpoints",
    "Support for all authentication mechanisms: HMAC, RSA, and Ed25519 (auto-detected from secret format)",
    "Smart WebSocket persistence with automatic reconnection, listenKey renewal, and reconnected event emission",
    "Optional response beautification: converts abbreviated keys to descriptive names and number strings to numbers",
    "Demo trading and testnet environment support via simple constructor options",
    "Browser/frontend support via webpack bundle in dist/",
    "Proxy support via axios integration"
  ],
  "publicApiSurface": [
    "MainClient",
    "USDMClient",
    "CoinMClient",
    "PortfolioClient",
    "WebsocketClient",
    "WebsocketAPIClient",
    "RestClientOptions",
    "WSClientConfigurableOptions",
