    "WebsocketClient.unsubscribe(topics, wsKey)",
    "WebsocketClient.subscribeSpotUserDataStream()",
    "WebsocketClient.subscribeCrossMarginUserDataStream()",
    "WebsocketClient.subscribeUsdFuturesUserDataStream()",
    "WebsocketClient.subscribeCoinFuturesUserDataStream()",
    "WebsocketClient.subscribePortfolioMarginUserDataStream()",
    "WebsocketClient.subscribeAggregateTrades(symbol, market)",
    "WebsocketClient.subscribeKlines(symbol, interval, market)",
    "WebsocketClient.subscribeMarkPrice(symbol, market)",
    "WebsocketClient.on('message' | 'formattedMessage' | 'formattedUserDataMessage' | 'open' | 'reconnected' | 'reconnecting' | 'error' | 'response')",
    "MainClient.testConnectivity()",
    "MainClient.getExchangeInfo()",
    "MainClient.submitNewOrder(params)",
    "MainClient.getOrder(params)",
    "MainClient.cancelOrder(params)",
    "MainClient.getAccountInformation()",
